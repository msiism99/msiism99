Sub CPE_raw_data_information(CPE_raw_size, how_many_wafers, how_many_tests, CPE_wafer_count, wafer_slot)

    '===================================================================================
    
    Dim wafers, wafer1, wafer2, tests, test1, test2, W As Long
    
    
'    how_many_wafers = ThisWorkbook.Sheets("Run").Range("D9").Value
    how_many_tests = ThisWorkbook.Sheets("Run").Range("D10").value
    
    
    
    
'======================================================================= data size 분석




  Set Rawsheet = ThisWorkbook.Sheets("CPE")
  
    CPE_raw_size = 1
    how_many_wafers = 1
    
    wafer_name_1 = Rawsheet.Cells(7, 2).value
   Do While IsEmpty(Rawsheet.Cells(7 + CPE_raw_size, 2).value) = False
             wafer_name_2 = Rawsheet.Cells(7 + CPE_raw_size, 2).value
             
             If wafer_name_1 <> wafer_name_2 Then
                how_many_wafers = how_many_wafers + 1
                wafer_name_1 = wafer_name_2
             End If
             
             
             
            CPE_raw_size = CPE_raw_size + 1
            
            
            
    Loop
   

            
            
    ReDim CPE_wafer_count(how_many_wafers), wafer_slot(how_many_wafers)
            
     wafers = 1
     tests = 1
     CPE_wafer_count(wafers) = 1
     
     
  If how_many_wafers = 1 Then wafer_slot(wafers) = Rawsheet.Cells(7, 2).value
     
  For t = 2 To CPE_raw_size
  
     wafer1 = Rawsheet.Cells(6 + t - 1, 2).value
     wafer2 = Rawsheet.Cells(6 + t, 2).value

  
        If wafer1 = wafer2 Then
                            CPE_wafer_count(wafers) = CPE_wafer_count(wafers) + 1
                            
                            
                            
                           Else:
                           
                            wafer_slot(wafers) = wafer1
                            wafers = wafers + 1
                            wafer_slot(wafers) = wafer2
                            
                            CPE_wafer_count(wafers) = 1

                            
       End If
       
  Next t


g = g


End Sub
