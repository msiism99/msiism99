Sub copy_raw()

' raw data 복사=========================================================================================================================
    
    Call raw_data_information(raw_size, how_many_wafers, how_many_tests, wafer_count, wafer_test_count, wafer_slot)

   
  
    
   
    On Error Resume Next
         Sheets("CPE").Visible = True

         Sheets("CPE").Select
         rows("7:7").Select
         Range(Selection, Selection.End(xlDown)).Select
         Selection.ClearContents
         rows("7:7").Select
         Range(Selection, Selection.End(xlDown)).Select
         Selection.ClearContents


         ThisWorkbook.Sheets("Raw data").Select


         Range("B6").Select

         CPE_row = 1



         For count = 1 To raw_size
             wafer = ActiveCell.Cells(count, 1).value
             test = ActiveCell.Cells(count, 2).value
             LocNOX = ActiveCell.Cells(count, 3).value
             LocNOY = ActiveCell.Cells(count, 4).value
             residual_X = ActiveCell.Cells(count, 5).value
             residual_Y = ActiveCell.Cells(count, 6).value
             outlier_color_x = ActiveCell.Cells(count, 5).Font.Color
             outlier_color_y = ActiveCell.Cells(count, 6).Font.Color


             If outlier_color_x = 0 And outlier_color_y = 0 Then

                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 2).value = wafer
                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 3).value = test
                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 4).value = LocNOX
                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 5).value = LocNOY
                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 6).value = residual_X
                ThisWorkbook.Sheets("CPE").Cells(CPE_row + 6, 7).value = residual_Y

                CPE_row = CPE_row + 1
             End If

         Next count

    On Error GoTo 0

   ThisWorkbook.Sheets("CPE").Select
   Range("B6").Select
   Application.StatusBar = "Raw Copy Completed."
   
End Sub


