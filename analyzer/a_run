Sub run_scanner()

Call side_map_clear


Regression_option = ThisWorkbook.Sheets("Option table").Range("D43").value


If Regression_option = True Then

   ThisWorkbook.Sheets("Option table").Range("D7").value = False
   ThisWorkbook.Sheets("Option table").Range("D40").value = False
   ThisWorkbook.Sheets("Option table").Range("D41").value = 1

    Call merge_analysis
    Call residual_wafer
    Call residual_reticle

Else
    
'    ThisWorkbook.Sheets("Option table").Range("D7").Value = True
    Call waferfield_analysis
    Call residual_wafer
    Call reticlefield_analysis
    Call residual_reticle

End If


Call forced_removal
Call fitting_sample
Call decoration
Call CPE_clear
Call TROCS_clear
Call vspec_control


drawing_map = ThisWorkbook.Sheets("Option table").Range("D10").value


If drawing_map = 1 Then

    draw_raw = ThisWorkbook.Sheets("Option table").Range("D32").value
    draw_residual = ThisWorkbook.Sheets("Option table").Range("D33").value
    draw_MRC = ThisWorkbook.Sheets("Option table").Range("D35").value
    draw_raw_MRC = ThisWorkbook.Sheets("Option table").Range("D36").value
    draw_spec = ThisWorkbook.Sheets("Option table").Range("D37").value
    
    select_map = ThisWorkbook.Sheets("Option table").Range("D24").value


    If draw_residual = True Then
    
       Call draw_residual_map
       
    End If
    
    
    If draw_raw = True Then
    
       Call draw_raw_map
       
    End If
       
    
    If draw_MRC = True Then
    
       Call draw_MRC_map
       
    End If
    
    If draw_raw_MRC = True Then

       Call draw_Raw_removed_MRC_map

    End If
    
    If draw_spec = True Then
    
       Call draw_spec_map("spring")
       
    End If
    
                  
End If



Call rdp_calculation

I_have_vector_spec = False

Application.StatusBar = "END ♬"

End Sub

Sub residual_simulation()

Call residual_wafer
Call residual_reticle
Call fitting_sample

Call vspec_control


drawing_map = ThisWorkbook.Sheets("Option table").Range("D10").value
drawing_residual_map = ThisWorkbook.Sheets("Output").Range("A13").value


If drawing_map = 1 Then

  Call draw_residual_map
                      
End If
 
If drawing_map = 2 And drawing_residual_map = True Then
       
 Call draw_residual_map
 
End If
      

Application.StatusBar = "residual  simulation end"

End Sub


