                            If count_prevent_fallback_retrun = 0 Then
                                
                                Select Case max_Y_hat_ii
                                
                                  Case Is >= G_opt_spec
                                        prevent_fall_back = True
                                       Call ridge_up_Gopt_fast(2, fast_return_Y, slow_return_Y, max_K_SIZE, virtual_points, Vgrid_XY, ramda_ridge_Y, ramda_ridge_edge_Y, add_ridge, _
                                                        max_Y_hat_ii, Ridge_parameter_XY, count_prevent_fallback_retrun, start_Gopt_Y, end_Gopt_Y, start_Ridge_Y, end_Ridge_Y, order_selection, ridge_valve_1st, ridge_valve_3rd, ridge_valve_hyper)
                                
                                  Case Is < Gopt_criteria_Y

