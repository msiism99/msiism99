                                     end_Ridge_Y = initial_ridge_Y

                                     Call ridge_up_Gopt_slow(2, fast_return_Y, slow_return_Y, max_K_SIZE, virtual_points, Vgrid_XY, add_ridge, Ridge_parameter_XY, count_prevent_fallback_retrun, start_Ridge_Y, end_Ridge_Y, next_Ridge_Y, order_selection, ridge_valve_1st, ridge_valve_3rd, ridge_valve_hyper)


                                End Select
                                
                            End If
                           
                   

                           '==========================================================================================================
                           
                               If count_prevent_fallback_retrun >= 10 And (next_Ridge_X < 10 ^ -5 Or next_Ridge_Y < 10 ^ -5) Then
                               
                                   
                                  
